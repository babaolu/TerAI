# ── TerAI runtime data (user-specific, never commit) ──────────────────────
# Config, API keys, history, patterns, daemon logs — all live in ~/.terai
# outside the repo, but ignore local copies just in case they end up here.
.terai/
*.terai_backup
config.json
history.json
patterns.json
daemon.log
daemon.pid
gmail_credentials.json
gmail_token.json
drive_token.json

# ── Secrets ────────────────────────────────────────────────────────────────
*.env
.env.*
*.key
*.pem
**/secrets.json

# ── Debug / sanitizer output ───────────────────────────────────────────────
*.dSYM/
/core
core.[0-9]*
vgcore.*
asan.log*
*.profraw
*.gcda
*.gcno

# ── Packaging artifacts ────────────────────────────────────────────────────
*.tar.gz
*.zip
*.deb

